#!/usr/bin/env php
<?php

declare(strict_types=1);

use Lemonade\Framework\Core\CliKernelFactory;
use Lemonade\Framework\Core\Context\ApplicationContextFactory;

$packageRoot = dirname(__DIR__);
$projectRoot = dirname($packageRoot);

$autoload = $packageRoot . '/vendor/autoload.php';

if (!is_file($autoload)) {
    $autoload = $projectRoot . '/vendor/autoload.php';
}

require $autoload;

$basePath = is_dir($projectRoot . '/app') && is_dir($projectRoot . '/storage')
    ? $projectRoot
    : $packageRoot;
$context = (new ApplicationContextFactory())->fromGlobals($basePath);

$argv = isset($_SERVER['argv']) && is_array($_SERVER['argv'])
    ? array_values($_SERVER['argv'])
    : [];

$kernel = (new CliKernelFactory())->create($context);

exit($kernel->handle($argv));
